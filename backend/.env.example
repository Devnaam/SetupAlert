# Razorpay Plan IDs
RAZORPAY_PLAN_MONTHLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_ANNUAL=plan_xxxxxxxxxxxx

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
